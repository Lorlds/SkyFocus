<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SkyFocus.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SkyFocus.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SkyFocus.Models"
    mc:Ignorable="d"
    x:DataType="local:HistoryPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource PageOuterMargin}" Spacing="24">
            <Border Style="{StaticResource HeroCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="HistoryHeroEyebrow" Style="{StaticResource MutedBodyStyle}" />
                    <TextBlock x:Uid="HistoryHeroTitle" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock x:Uid="HistoryHeroSubtitle" Style="{StaticResource MutedBodyStyle}" />
                </StackPanel>
            </Border>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardSurfaceStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="HistoryDailyTitle" Style="{StaticResource SectionTitleStyle}" />
                        <ListView ItemsSource="{x:Bind ViewModel.DailySummaries, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:DailySummaryItem">
                                    <StackPanel Padding="0,8" Spacing="8">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="{x:Bind DateLabel}" /><TextBlock Grid.Column="1" Text="{x:Bind MinutesLabel}" FontWeight="SemiBold" /></Grid>
                                        <ProgressBar Minimum="0" Maximum="1" Value="{x:Bind CompletionValue}" Height="6" />
                                        <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{x:Bind SessionsLabel}" Style="{StaticResource MutedBodyStyle}" /><TextBlock Grid.Column="1" Text="{x:Bind CompletionLabel}" Style="{StaticResource MutedBodyStyle}" HorizontalAlignment="Right" /></Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardSurfaceStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="HistoryRecentTitle" Style="{StaticResource SectionTitleStyle}" />
                        <ListView ItemsSource="{x:Bind ViewModel.RecentSessions, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:HistorySessionItem">
                                    <Grid Padding="0,10">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2"><TextBlock Text="{x:Bind RouteLabel}" FontWeight="SemiBold" /><TextBlock Text="{x:Bind TagLabel}" Style="{StaticResource MutedBodyStyle}" /></StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind DurationLabel}" FontWeight="SemiBold" />
                                        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="{x:Bind DateLabel}" Style="{StaticResource MutedBodyStyle}" /><TextBlock Grid.Column="1" Text="{x:Bind StatusLabel}" Style="{StaticResource MutedBodyStyle}" /></Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>