<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SkyFocus.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SkyFocus.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DataType="local:SettingsPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource PageOuterMargin}" Spacing="24">
            <Border Style="{StaticResource HeroCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="SettingsHeroEyebrow" Style="{StaticResource MutedBodyStyle}" />
                    <TextBlock x:Uid="SettingsHeroTitle" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock x:Uid="SettingsHeroSubtitle" Style="{StaticResource MutedBodyStyle}" />
                </StackPanel>
            </Border>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardSurfaceStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="SettingsDefaultsTitle" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock x:Uid="SettingsDefaultMinutesLabel" Style="{StaticResource MutedBodyStyle}" />
                        <ComboBox ItemsSource="{x:Bind SessionPresets}" SelectedItem="{x:Bind ViewModel.DefaultSessionMinutes, Mode=TwoWay}" />
                        <TextBlock x:Uid="SettingsThemeLabel" Style="{StaticResource MutedBodyStyle}" />
                        <ComboBox ItemsSource="{x:Bind ThemeOptions}" SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardSurfaceStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="SettingsBlockerTitle" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock x:Uid="SettingsSoftBlockerLabel" Style="{StaticResource MutedBodyStyle}" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.EnableSoftBlocker, Mode=TwoWay}" />
                        <TextBlock x:Uid="SettingsShieldLabel" Style="{StaticResource MutedBodyStyle}" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.UseFocusShield, Mode=TwoWay}" />
                        <TextBlock x:Uid="SettingsTopMostLabel" Style="{StaticResource MutedBodyStyle}" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.KeepWindowOnTop, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CardSurfaceStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="SettingsNotificationsTitle" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock x:Uid="SettingsSystemNotificationsLabel" Style="{StaticResource MutedBodyStyle}" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.SendSystemNotifications, Mode=TwoWay}" />
                        <TextBlock x:Uid="SettingsFiveMinuteLabel" Style="{StaticResource MutedBodyStyle}" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.NotifyAtFiveMinutes, Mode=TwoWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Uid="SettingsSaveButton" Click="OnSaveClick" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Uid="SettingsRestoreButton" Click="OnRestoreClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>