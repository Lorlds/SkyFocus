<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SkyFocus.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SkyFocus.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SkyFocus.Models"
    mc:Ignorable="d"
    x:DataType="local:HomePage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource PageOuterMargin}" Spacing="24">
            <Border Style="{StaticResource HeroCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="HomeHeroEyebrow" Style="{StaticResource MutedBodyStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.JourneyTitle, Mode=OneWay}" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.JourneySubtitle, Mode=OneWay}" Style="{StaticResource MutedBodyStyle}" />
                    <Button x:Uid="HomeLaunchFocusButton" Click="OnOpenFocusClick" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="HomeTodayMinutesLabel" Style="{StaticResource MutedBodyStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.TodayMinutesText, Mode=OneWay}" Style="{StaticResource MetricValueStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="HomeTodaySessionsLabel" Style="{StaticResource MutedBodyStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.TodaySessionsText, Mode=OneWay}" Style="{StaticResource MetricValueStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="HomeStreakLabel" Style="{StaticResource MutedBodyStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.StreakText, Mode=OneWay}" Style="{StaticResource MetricValueStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardSurfaceStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="HomeRouteMixTitle" Style="{StaticResource SectionTitleStyle}" />
                        <ListView ItemsSource="{x:Bind ViewModel.TopTags, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:TagBreakdown">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="18" />
                                            <TextBlock Text="{x:Bind DisplayName}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind MinutesFocused}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardSurfaceStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="HomeBadgeTitleLabel" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.BadgeTitle, Mode=OneWay}" Style="{StaticResource MetricValueStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.BadgeDescription, Mode=OneWay}" Style="{StaticResource MutedBodyStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>